#!/usr/bin/env bash
# Post-install setup — pacman, flatpak, and official upstream installers only. No AUR.

set -euo pipefail

# reset KDE to stock settings
rm -rf ~/.config/plasma* ~/.config/kde* ~/.local/share/plasma* ~/.cache/plasma

# update system
sudo pacman -Syu

# flatpak
sudo pacman -S --needed --noconfirm flatpak
flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo

# dinit-user-spawn
sudo pacman -S --needed --noconfirm dinit-user-spawn

# power profile daemon
sudo pacman -Syu --needed --noconfirm tlp power-profiles-daemon powerdevil power-profiles-daemon-dinit

# enable power profile daemon
sudo dinitctl enable power-profiles-daemon

# ufw
sudo pacman -S --needed --noconfirm ufw ufw-dinit
sudo dinitctl enable ufw

# remove wacomtablet
sudo pacman -R --noconfirm wacomtablet 2>/dev/null || true

# nomachine (official tar.gz — not in repos)
NOMACHINE_TAR="/tmp/nomachine.tar.gz"
curl -fsSL "https://www.nomachine.com/free/linux/64/tar" -o "$NOMACHINE_TAR"
tmpdir="$(mktemp -d)"
tar -xzf "$NOMACHINE_TAR" -C "$tmpdir"
sudo "$tmpdir"/NoMachine/nxserver --install
rm -rf "$tmpdir" "$NOMACHINE_TAR"
mkdir -p "$HOME/.nx/config"
touch "$HOME/.nx/config/player.cfg"
sed -i 's/^\(Enable hardware accelerated decoding *= *\).*/\1"disabled"/' "$HOME/.nx/config/player.cfg"

# openvpn support
sudo pacman -S --needed --noconfirm networkmanager-openvpn

# brave (Flathub)
sudo pacman -S --needed --noconfirm wget
flatpak install -y flathub com.brave.Browser

# run "Brave Debullshitinator" (targets native Brave; skip if you only use Flatpak)
# bash <(curl -s https://raw.githubusercontent.com/MulesGaming/brave-debloatinator/main/brave-bullshitinator-linux-install.sh)

# shit for virtualization
sudo usermod -aG kvm,libvirt,wheel,storage "$USER"
sudo pacman -S --needed --noconfirm spice-gtk spice-vdagent virt-manager

# printer network address resolution
sudo pacman -Sy --needed --noconfirm avahi-dinit nss-mdns
sudo dinitctl start avahi-daemon
grep -q "mdns_minimal" /etc/nsswitch.conf || sudo sed -i 's/hosts: \(.*\)dns/hosts: \1mdns_minimal [NOTFOUND=return] dns/' /etc/nsswitch.conf

# online account integration
sudo pacman -S --needed --noconfirm kio-gdrive kaccounts-integration kaccounts-providers

# appimagetool (official AppImage — self-contained, no AUR build)
mkdir -p "$HOME/.local/bin"
curl -fsSL "https://github.com/AppImage/AppImageKit/releases/download/continuous/appimagetool-x86_64.AppImage" \
  -o "$HOME/.local/bin/appimagetool"
chmod +x "$HOME/.local/bin/appimagetool"

# protondrive support
sudo pacman -S --needed --noconfirm rclone
mkdir -p ~/ProtonDrive
rclone config

sudo tee /etc/dinit.d/user/protondrive > /dev/null <<EOF
# Service type for background process
type: process

# The command to run (use absolute path!)
command: /usr/bin/rclone mount ProtonDrive: /home/$(id -un)/ProtonDrive --vfs-cache-mode full

# PID file location (required for bgprocess)
pid-file: /run/dinit/protondrive.pid

# Restart policy
restart: true
EOF

dinitctl enable protondrive

# stupid kioworker bug workaround
if command -v kwriteconfig6 &>/dev/null; then
  kwriteconfig6 --file kdeglobals --group PreviewSettings --key SkipRemovableDevices true
  kwriteconfig6 --file kdeglobals --group PreviewSettings --key Tooltips false
else
  sed -i '/\[PreviewSettings\]/,/^\[/ { /SkipRemovableDevices=/d; /Tooltips=/d; }' ~/.config/kdeglobals
  if ! grep -q "\[PreviewSettings\]" ~/.config/kdeglobals; then
    echo -e "\n[PreviewSettings]" >> ~/.config/kdeglobals
  fi
  sed -i '/\[PreviewSettings\]/a SkipRemovableDevices=true\nTooltips=false' ~/.config/kdeglobals
fi

# Ollama
curl -fsSL https://ollama.com/install.sh | sh

sudo tee /etc/dinit.d/user/ollama > /dev/null <<EOF
type            = process
command         = /usr/local/bin/ollama serve
restart         = false
smooth-recovery = true
log-type        = buffer
EOF

dinitctl enable ollama

# Virtualbox
sudo pacman -Syu --needed --noconfirm virtualbox \
  $([[ $(uname -r) == *"-arch"* ]] && echo "virtualbox-host-modules-arch" || echo "virtualbox-host-dkms linux-headers")
sudo modprobe vboxdrv vboxnetadp vboxnetflt
sudo mkdir -p /etc/modules-load.d
echo -e "vboxdrv\nvboxnetadp\nvboxnetflt" | sudo tee /etc/modules-load.d/virtualbox.conf
sudo gpasswd -a "$USER" vboxusers

echo -e "\n--- Installation & Configuration Complete ---\nNote: If the kernel was updated during this process, please reboot.\nOtherwise, just log out and back in to refresh your group permissions."

# set default text editor to kate
xdg-mime default org.kde.kate.desktop text/plain
xdg-mime default org.kde.kate.desktop application/x-zerosize
xdg-mime default org.kde.kate.desktop text/markdown

#paru
sudo pacman -S --needed base-devel git && \
git clone https://aur.archlinux.org/paru.git /tmp/paru && \
cd /tmp/paru && \
makepkg -si && \
cd ~ && rm -rf /tmp/paru

# paru — chroot build support via artools shims
sudo pacman -S --needed --noconfirm artools-pkg
sudo ln -sf /usr/bin/mkchrootpkg  /usr/local/bin/makechrootpkg
sudo ln -sf /usr/bin/mkchroot     /usr/local/bin/mkarchroot
sudo ln -sf /usr/bin/chroot-run   /usr/local/bin/arch-nspawn

sudo tee /etc/paru.conf > /dev/null << 'EOF'
#
# $PARU_CONF
# /etc/paru.conf
# ~/.config/paru/paru.conf
#
# See the paru.conf(5) manpage for options

#
# GENERAL OPTIONS
#
[options]
PgpFetch
Devel
Provides
DevelSuffixes = -git -cvs -svn -bzr -darcs -always -hg -fossil
#AurOnly
#BottomUp
#RemoveMake
#SudoLoop
UseAsk
SaveChanges
#CombinedUpgrade
CleanAfter
UpgradeMenu
#NewsOnUpgrade

#LocalRepo
Chroot
#Sign
#SignDb
#KeepRepoCache

#
# Binary OPTIONS
#
#[bin]
#FileManager = vifm
#MFlags = --skippgpcheck
#Sudo = doas
EOF




