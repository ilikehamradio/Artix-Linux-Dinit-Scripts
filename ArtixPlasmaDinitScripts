#reset KDE to stock settings
rm -rf ~/.config/plasma* ~/.config/kde* ~/.local/share/plasma* ~/.cache/plasma

#update system
sudo pacman -Syu

#install yay
sudo pacman -S --needed --noconfirm git base-devel && git clone https://aur.archlinux.org/yay.git /tmp/yay && cd /tmp/yay && makepkg -si --noconfirm && cd - && rm -rf /tmp/yay

#install flatpak
yay -S flatpak

#install dinit-user-spawn
sudo pacman -S dinit-user-spawn

#install power profile daemon
sudo pacman -Syu tlp power-profiles-daemon powerdevil power-profiles-daemon-dinit

#enable power profile daemon
sudo dinitctl enable power-profiles-daemon

#remove wacomtablet
sudo pacman -R wacomtablet

#install brave
yay -S brave-bin wget

#run "Brave Debullshitinator"
bash <(curl -s https://raw.githubusercontent.com/MulesGaming/brave-debloatinator/main/brave-bullshitinator-linux-install.sh)

#shit for virtualization
sudo usermod -aG kvm,libvirt,wheel,storage $USER
sudo pacman -S spice-gtk spice-vdagent virt-manager

#printer network address resolution
sudo pacman -Sy --needed avahi-dinit nss-mdns
sudo dinitctl start avahi-daemon
grep -q "mdns_minimal" /etc/nsswitch.conf || sudo sed -i 's/hosts: \(.*\)dns/hosts: \1mdns_minimal [NOTFOUND=return] dns/' /etc/nsswitch.conf

#appimagetool - broken dependency fix. Needs zsync2, not zsync
yay -G appimagetool-bin && cd appimagetool-bin && sed -i 's/zsync/zsync2/g' PKGBUILD && makepkg -si

#Ollama
yay -S ollama-cuda13-bin ollama-dinit --overwrite
cd /tmp
wget https://github.com/ollama/ollama/releases/download/v0.5.11/ollama-linux-amd64.tgz -O ollama.tgz
tar -xzf ollama.tgz
sudo mkdir -p /usr/lib/ollama/runners
sudo cp -r /tmp/lib/ollama/cuda_v* /usr/lib/ollama/runners/ 
sudo cp /tmp/lib/ollama/libggml* /usr/lib/ollama/
sudo ln -sf /usr/lib/libnvidia-ml.so* /usr/lib/ollama/
sudo ln -sf /usr/lib/libcuda.so* /usr/lib/ollama/
sudo cp -r /usr/lib/ollama/runners/* /usr/lib/ollama/

dinitctl enable ollama
